# ==================================================
# SALA 205 - VARIÁVEIS DE AMBIENTE (.env)
# ==================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para .env
# 2. Preencha os valores com suas credenciais
# 3. NUNCA commite este arquivo no Git
# 4. Adicione .env ao .gitignore
#
# ==================================================

# ==================================================
# SUPABASE CONFIGURATION
# ==================================================
# Obtenha estas chaves em: https://supabase.com

# URL do seu projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (safe para usar no cliente)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave privada (service role - APENAS NO SERVIDOR)
# NUNCA exponha esta chave no cliente!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==================================================
# SERVER CONFIGURATION
# ==================================================

# Porta do servidor
PORT=3000

# Ambiente (development/production)
# development = logs detalhados, sem compressão
# production = otimizado para produção
NODE_ENV=development

# ==================================================
# NOTAS IMPORTANTES
# ==================================================
#
# - Não compartilhe a chave SUPABASE_SERVICE_ROLE_KEY
# - Mude NODE_ENV para 'production' ao fazer deploy
# - Se PORT estiver em uso, tente: 3001, 3002, etc.
# - Mantendo .env fora do Git (adicione ao .gitignore)
#
# ==================================================