# Supabase Configuration
# Copie este arquivo para `.env` e preencha com suas credenciais

# URL do seu projeto Supabase (encontre em Project Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública do Supabase (anon key - encontre em Project Settings > API)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço para operações administrativas (uso recomendado no backend)
SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key-aqui

# Porta do servidor (padrão: 3000)
PORT=3000

